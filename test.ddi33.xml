      <r:URN>urn:ddi:example.org:CodeList_Satisfaction:1</r:URN>
      <r:Agency>example.org</r:Agency>
      <r:ID>CodeList_Satisfaction</r:ID>
      <r:Version>1.0.0</r:Version>
      <r:Label><r:Content xml:lang="en">Satisfaction Scale (1-4)</r:Content></r:Label>
      <r:Description><r:Content xml:lang="en">Original four-point scale without neutral midpoint. Superseded by v2.0.0.</r:Content></r:Description>
