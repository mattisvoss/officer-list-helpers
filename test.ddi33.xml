<?xml version="1.0" encoding="UTF-8"?>
<!--
  test_instrument.xml — DDI Lifecycle 3.3 integration test fixture
  FragmentInstance style (flat fragments, as produced by Colectica and DDI REST APIs)

  Statements describe what they are. Questions ask "Is it visible?"

  CHECKLIST — at least one of each:
    [x] Category (versioned, with Agency/ID/Version)
    [x] CodeList (two versions: v1.0.0 and v2.0.0)
    [x] QuestionItem with text response domain
    [x] QuestionItem with code response domain
    [x] QuestionGrid with two dimensions
    [x] Sequence (main)
    [x] Sequence (nested, referenced by Loop)
    [x] StatementItem (plain text)
    [x] StatementItem (HTML: p, b, i, ol, ul)
    [x] QuestionConstruct referencing QuestionItem
    [x] QuestionConstruct referencing QuestionGrid
    [x] QuestionConstruct with two versions (v1.0.0 and v1.1.0)
    [x] IfThenElse with condition, Then, Else
    [x] Loop with InitialValue, LoopWhile, StepValue
    [x] Instrument referencing main Sequence

  EDGE CASES:
    [x] All references use both URN and Agency/ID/Version/TypeOfObject
    [x] CodeList v2.0.0 references Category v1.0.0 (cross-version)
    [x] QuestionConstruct exists in two versions; Sequence references v1.1.0
    [x] Satisfaction CodeList exists in v1.0.0 and v2.0.0; QuestionGrid references v2.0.0
    [x] Loop references a Sequence which reuses a QuestionConstruct from the main flow
-->
<ddi:FragmentInstance
    xmlns:ddi="ddi:instance:3_3"
    xmlns:d="ddi:datacollection:3_3"
    xmlns:g="ddi:group:3_3"
    xmlns:l="ddi:logicalproduct:3_3"
    xmlns:r="ddi:reusable:3_3"
    xmlns:xhtml="http://www.w3.org/1999/xhtml"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">


