        <d:LiteralText>
          <d:Text xml:lang="en">This is a QuestionItem with a code response domain referencing the Yes/No CodeList. Is it visible?</d:Text>
        </d:LiteralText>
      </d:QuestionText>
      <d:CodeDomain>
        <r:CodeListReference>
          <r:URN>urn:ddi:example.org:CodeList_YesNo:1</r:URN>
          <r:Agency>example.org</r:Agency>
          <r:ID>CodeList_YesNo</r:ID>
          <r:Version>1.0.0</r:Version>
          <r:TypeOfObject>CodeList</r:TypeOfObject>
        </r:CodeListReference>
      </d:CodeDomain>
    </d:QuestionItem>
  </ddi:Fragment>

  <!-- QuestionGrid references Satisfaction v2.0.0 (not v1.0.0) -->
  <ddi:Fragment>
    <d:QuestionGrid>
      <r:URN>urn:ddi:example.org:QuestionGrid_Matrix:1</r:URN>
      <r:Agency>example.org</r:Agency>
      <r:ID>QuestionGrid_Matrix</r:ID>
      <r:Version>1.0.0</r:Version>
      <d:QuestionGridName>
        <r:String xml:lang="en">service_satisfaction</r:String>
      </d:QuestionGridName>
      <d:QuestionText>
        <d:LiteralText>
          <d:Text xml:lang="en">This is a QuestionGrid with two dimensions. Rows use Satisfaction v2.0.0 (5-point), columns use Yes/No v1.0.0. Is it visible?</d:Text>
        </d:LiteralText>
      </d:QuestionText>
      <d:GridDimension rank="1" displayCode="false" displayLabel="true">
        <d:CodeDomain>
          <r:CodeListReference>
            <r:URN>urn:ddi:example.org:CodeList_Satisfaction:2</r:URN>
            <r:Agency>example.org</r:Agency>
            <r:ID>CodeList_Satisfaction</r:ID>
            <r:Version>2.0.0</r:Version>
            <r:TypeOfObject>CodeList</r:TypeOfObject>
          </r:CodeListReference>
        </d:CodeDomain>
      </d:GridDimension>
      <d:GridDimension rank="2" displayCode="false" displayLabel="true">
        <d:CodeDomain>
          <r:CodeListReference>
            <r:URN>urn:ddi:example.org:CodeList_YesNo:1</r:URN>
            <r:Agency>example.org</r:Agency>
            <r:ID>CodeList_YesNo</r:ID>
            <r:Version>1.0.0</r:Version>
            <r:TypeOfObject>CodeList</r:TypeOfObject>
          </r:CodeListReference>
        </d:CodeDomain>
      </d:GridDimension>
    </d:QuestionGrid>
  </ddi:Fragment>


