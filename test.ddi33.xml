  <!-- StatementItem: plain text -->
  <ddi:Fragment>
    <d:StatementItem>
      <r:URN>urn:ddi:example.org:StatementItem_PlainText:1</r:URN>
      <r:Agency>example.org</r:Agency>
      <r:ID>StatementItem_PlainText</r:ID>
      <r:Version>1.0.0</r:Version>
      <d:ConstructName><r:String xml:lang="en">PlainTextStatement</r:String></d:ConstructName>
      <d:DisplayText>
        <d:LiteralText>
          <d:Text xml:lang="en">This is a plain text StatementItem with no HTML formatting.</d:Text>
        </d:LiteralText>
      </d:DisplayText>
    </d:StatementItem>
  </ddi:Fragment>


  <!-- StatementItem: HTML formatted -->
  <ddi:Fragment>
    <d:StatementItem>
      <r:URN>urn:ddi:example.org:StatementItem_WithHTML:1</r:URN>
      <r:Agency>example.org</r:Agency>
      <r:ID>StatementItem_WithHTML</r:ID>
      <r:Version>1.0.0</r:Version>
      <d:ConstructName><r:String xml:lang="en">HTMLFormattedStatement</r:String></d:ConstructName>
      <d:DisplayText>
        <d:LiteralText>
          <d:Text xml:lang="en"><![CDATA[<p>This is an HTML-formatted StatementItem. The word <b>BOLD</b> should be bold. The word <i>ITALIC</i> should be italic. The words <b><i>BOLD-ITALIC</i></b> should be both.</p>
<p>This is a second paragraph within the same StatementItem.</p>
<p>The following is an ordered list:</p>
<ol>
  <li>Ordered list item one.</li>
  <li>Ordered list item two with <b>BOLD</b> formatting.</li>
  <li>Ordered list item three with <i>ITALIC</i> formatting.</li>
</ol>
<p>The following is an unordered list:</p>
<ul>
  <li>Unordered list item one.</li>
  <li>Unordered list item two with <b>BOLD</b> formatting.</li>
  <li>Unordered list item three with <i>ITALIC</i> formatting.</li>
</ul>
<p>This is the final paragraph after the lists.</p>]]></d:Text>
        </d:LiteralText>
      </d:DisplayText>
    </d:StatementItem>
  </ddi:Fragment>


