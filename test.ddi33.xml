      <l:Code>
        <r:Value>1</r:Value>
        <r:CategoryReference>
          <r:URN>urn:ddi:example.org:Category_Yes:1</r:URN>
          <r:Agency>example.org</r:Agency>
          <r:ID>Category_Yes</r:ID>
          <r:Version>1.0.0</r:Version>
          <r:TypeOfObject>Category</r:TypeOfObject>
        </r:CategoryReference>
      </l:Code>
      <l:Code>
        <r:Value>2</r:Value>
