        <r:URN>urn:ddi:example.org:QuestionConstruct_Coded:2</r:URN>
        <r:Agency>example.org</r:Agency>
        <r:ID>QuestionConstruct_Coded</r:ID>
        <r:Version>1.1.0</r:Version>
        <r:TypeOfObject>QuestionConstruct</r:TypeOfObject>
      </d:ControlConstructReference>

      <d:ControlConstructReference>
        <r:URN>urn:ddi:example.org:IfThenElse_Branch:1</r:URN>
        <r:Agency>example.org</r:Agency>
